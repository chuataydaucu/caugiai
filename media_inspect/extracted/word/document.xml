r id="21" name="image7.png"/><wp:cNvGraphicFramePr/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="image7.png"/><pic:cNvPicPr preferRelativeResize="0"/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId4"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="3423920" cy="3423920"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln/></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:anchor></w:drawing></w:r><w:r><w:t>💎 Intro</w:t></w:r></w:p><w:p w14:paraId="69DFB994" w14:textId="0DFC3538" w:rsidR="004C40AA" w:rsidRPr="00A009AF" w:rsidRDefault="00000000"><w:pPr><w:rPr><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:t>This paper aims to explain the way .bpz and .sol files work in Bejeweled 2 so you can make your own! All this is explained using a hex editor.</w:t></w:r></w:p><w:p w14:paraId="46DF59E7" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="0188C56B" w14:textId="0F34DB70" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Title"/></w:pPr><w:bookmarkStart w:id="2" w:name="_gqtl85wvqy92" w:colFirst="0" w:colLast="0"/><w:bookmarkEnd w:id="2"/><w:r><w:t>BPZ Puzzle Explanation</w:t></w:r></w:p><w:p w14:paraId="770A4CD2" w14:textId="18206C60" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>Let’s take this custom puzzle for example:</w:t></w:r></w:p><w:p w14:paraId="613201E9" w14:textId="419AACE3" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="3AB87CD4" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>This is the bpz file opened with HXD:</w:t></w:r></w:p><w:p w14:paraId="5299A77B" w14:textId="7B65A248" w:rsidR="004C40AA" w:rsidRDefault="00667DC1"><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:anchor distT="0" distB="0" distL="114300" distR="114300" simplePos="0" relativeHeight="251660288" behindDoc="0" locked="0" layoutInCell="1" allowOverlap="1" wp14:anchorId="2DCBA523" wp14:editId="15FBD210"><wp:simplePos x="0" y="0"/><wp:positionH relativeFrom="margin"><wp:align>center</wp:align></wp:positionH><wp:positionV relativeFrom="page"><wp:posOffset>5648325</wp:posOffset></wp:positionV><wp:extent cx="6672580" cy="3625215"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:wrapTopAndBottom/><wp:docPr id="1240013297" name="Picture 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 1"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId5"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="6672580" cy="3625215"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic><wp14:sizeRelH relativeFrom="margin"><wp14:pctWidth>0</wp14:pctWidth></wp14:sizeRelH><wp14:sizeRelV relativeFrom="margin"><wp14:pctHeight>0</wp14:pctHeight></wp14:sizeRelV></wp:anchor></w:drawing></w:r></w:p><w:p w14:paraId="6BBB0B0C" w14:textId="4C628A6F" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="01A3C4BF" w14:textId="275DEFF3" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="02BF90C2" w14:textId="78B6709F" w:rsidR="004C40AA" w:rsidRDefault="00667DC1"><w:r><w:br w:type="page"/></w:r><w:r><w:lastRenderedPageBreak/><w:t>So how does it work?</w:t></w:r></w:p><w:p w14:paraId="0A210CE4" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="30F83E76" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t xml:space="preserve">First we have a header text, or bytes that pretty much say “this is how this file starts”. We are gonna be using this every time we make a .bpz file. </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Keep in mind the value of 0x04 offset</w:t></w:r><w:r><w:t xml:space="preserve">. For some reason, a value of 01 will mean that every 07 gem is a rock and 08 is a bomb. If the value is 02, then a gem with value 08 is a bomb and a value of 07 is a rock. I have no idea why this exists in the first place but keep it in mind. </w:t></w:r></w:p><w:p w14:paraId="3E8105D6" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="76C9C2B9" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>Then, the gems from the top left corner start. Each byte represents one gem, starting from the first line until the very last one. Depending on what gem we have, it might be stored in more than one bytes.</w:t></w:r></w:p><w:p w14:paraId="35402732" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>An empty gem</w:t></w:r><w:r><w:t xml:space="preserve"> (FF) is stored in only one byte. </w:t></w:r></w:p><w:p w14:paraId="792C89E5" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>A normal gem</w:t></w:r><w:r><w:t xml:space="preserve"> is stored in 2 bytes. The first byte is the skin color and the second byte represents if it’s powered (01) or not (00). The skin colors are shown in the picture starting from 00 until 09. </w:t></w:r></w:p><w:p w14:paraId="3CB30323" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t xml:space="preserve">Lastly, a gem with skin value of 07 is </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>a bomb</w:t></w:r><w:r><w:t xml:space="preserve"> and takes 3 bytes instead of 2. The reason for that is that we need to know the value of the bomb on the third byte (in the image, that value is 09, so the bomb will have the value 9).</w:t></w:r></w:p><w:p w14:paraId="3A8C33C0" w14:textId="6265A77E" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="2FAA2504" w14:textId="4F63C5AA" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="67F2FB51" w14:textId="41A2E92B" w:rsidR="00667DC1" w:rsidRDefault="00667DC1"><w:pPr><w:rPr><w:sz w:val="52"/><w:szCs w:val="52"/></w:rPr></w:pPr><w:bookmarkStart w:id="3" w:name="_qklixx7ixebe" w:colFirst="0" w:colLast="0"/><w:bookmarkEnd w:id="3"/><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:anchor distT="0" distB="0" distL="114300" distR="114300" simplePos="0" relativeHeight="251662336" behindDoc="0" locked="0" layoutInCell="1" allowOverlap="1" wp14:anchorId="24BB49C0" wp14:editId="736D3955"><wp:simplePos x="0" y="0"/><wp:positionH relativeFrom="margin"><wp:align>center</wp:align></wp:positionH><wp:positionV relativeFrom="page"><wp:posOffset>5010785</wp:posOffset></wp:positionV><wp:extent cx="6672580" cy="3625215"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:wrapTopAndBottom/><wp:docPr id="250663764" name="Picture 1" descr="The image shows a hexadecimal data representation with color-coded bytes indicating power status (yellow for no power, white for powered), object types (rock, bomb), and additional values for different colors (orange, green, blue, red, purple).&#xA;&#xA;AI-generated content may be incorrect."/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="250663764" name="Picture 1" descr="The image shows a hexadecimal data representation with color-coded bytes indicating power status (yellow for no power, white for powered), object types (rock, bomb), and additional values for different colors (orange, green, blue, red, purple).&#xA;&#xA;AI-generated content may be incorrect."/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId5"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="6672580" cy="3625215"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic><wp14:sizeRelH relativeFrom="margin"><wp14:pctWidth>0</wp14:pctWidth></wp14:sizeRelH><wp14:sizeRelV relativeFrom="margin"><wp14:pctHeight>0</wp14:pctHeight></wp14:sizeRelV></wp:anchor></w:drawing></w:r><w:r><w:br w:type="page"/></w:r></w:p><w:p w14:paraId="2D5AE33F" w14:textId="2AD5D256" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Title"/></w:pPr><w:r><w:lastRenderedPageBreak/><w:t>SOL Puzzle Explanation</w:t></w:r></w:p><w:p w14:paraId="3AF2E63A" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>A .sol file is used to determine the hints and all possible solutions in a step-by-step way on how to solve said puzzle.</w:t></w:r></w:p><w:p w14:paraId="5A8AB9BF" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:bookmarkStart w:id="4" w:name="_1uvvmmjo9e74" w:colFirst="0" w:colLast="0"/><w:bookmarkEnd w:id="4"/><w:r><w:t>Reading and understanding a .sol file</w:t></w:r></w:p><w:p w14:paraId="1704C169" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>Here is the hex-editor look of “26. Green right.sol” which connects to the puzzle in Centauri - 3 of the base game’s “Galaxy One”</w:t></w:r></w:p><w:p w14:paraId="2C7C97A3" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="114300" distB="114300" distL="114300" distR="114300" wp14:anchorId="498979B6" wp14:editId="3A0F1E19"><wp:extent cx="5972175" cy="971550"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="1" name="image5.png"/><wp:cNvGraphicFramePr/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="image5.png"/><pic:cNvPicPr preferRelativeResize="0"/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId6"/><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5972175" cy="971550"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln/></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="42D20E6C" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="0F8026A5" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>Since this example goes one way, it’s relatively simple to point on where the solution goes to and how to solve it</w:t></w:r></w:p><w:p w14:paraId="42574083" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="2852C0C0" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>Below is a detailed view of how a .sol file is read ingame</w:t></w:r></w:p><w:p w14:paraId="09B95374" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="114300" distB="114300" distL="114300" distR="114300" wp14:anchorId="71027CE5" wp14:editId="077E58E7"><wp:extent cx="5895975" cy="3276600"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="17" name="image9.png"/><wp:cNvGraphicFramePr/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="image9.png"/><pic:cNvPicPr preferRelativeResize="0"/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId7"/><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5895975" cy="3276600"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln/></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="25C34A7B" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="0C3DD032" w14:textId="77777777" w:rsidR="00667DC1" w:rsidRDefault="00667DC1"><w:r><w:br w:type="page"/></w:r></w:p><w:p w14:paraId="500D1325" w14:textId="403D56F5" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:lastRenderedPageBreak/><w:t>And how a hint is stored listed in detail here</w:t></w:r></w:p><w:p w14:paraId="20A450B4" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="114300" distB="114300" distL="114300" distR="114300" wp14:anchorId="15254533" wp14:editId="51DC809B"><wp:extent cx="5895975" cy="2028825"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="4" name="image12.png"/><wp:cNvGraphicFramePr/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="image12.png"/><pic:cNvPicPr preferRelativeResize="0"/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId8"/><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5895975" cy="2028825"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln/></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="5AB8D032" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="56E974F8" w14:textId="6ED40802" w:rsidR="004C40AA" w:rsidRPr="00667DC1" w:rsidRDefault="00000000"><w:pPr><w:rPr><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:t>If the number of possible hints in a state is more than 01, add an additional 4 bytes for however many times the number is (02: add 4 bytes, 03: add 8 bytes, etc.)</w:t></w:r></w:p><w:p w14:paraId="0DFFBF04" w14:textId="57442185" w:rsidR="004C40AA" w:rsidRPr="00667DC1" w:rsidRDefault="00000000"><w:pPr><w:rPr><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:t>Some hint arrow positions may crash the game due to an overflow error with no crash window or report.</w:t></w:r></w:p><w:p w14:paraId="36DDD1FB" w14:textId="6BC6E1A0" w:rsidR="004C40AA" w:rsidRPr="00667DC1" w:rsidRDefault="00000000"><w:pPr><w:rPr><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:t>If a specific move is made, the game will read as that solution was taken and will show the next hints at that state.</w:t></w:r></w:p><w:p w14:paraId="10549C25" w14:textId="47CAB00F" w:rsidR="004C40AA" w:rsidRPr="00667DC1" w:rsidRDefault="00000000"><w:pPr><w:rPr><w:lang w:val="en-US"/></w:rPr></w:pPr><w:r><w:t>The last 2 bytes you do not change, doing so will crash the game.</w:t></w:r></w:p><w:p w14:paraId="18F6E706" w14:textId="3FC73A08" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>All the arrow position values are listed below, values not listed would crash the game</w:t></w:r></w:p><w:p w14:paraId="530991C4" w14:textId="60E23E7C" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="3129FC13" w14:textId="33FD2764" w:rsidR="004C40AA" w:rsidRDefault="00667DC1"><w:pPr><w:jc w:val="center"/><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:noProof/></w:rPr><w:drawing><wp:anchor distT="0" distB="0" distL="114300" distR="114300" simplePos="0" relativeHeight="251663360" behindDoc="0" locked="0" layoutInCell="1" allowOverlap="1" wp14:anchorId="133E944D" wp14:editId="11DCE67F"><wp:simplePos x="0" y="0"/><wp:positionH relativeFrom="margin"><wp:align>center</wp:align></wp:positionH><wp:positionV relativeFrom="margin"><wp:align>bottom</wp:align></wp:positionV><wp:extent cx="4391025" cy="4446905"/><wp:effectExtent l="0" t="0" r="9525" b="0"/><wp:wrapTopAndBottom/><wp:docPr id="25" name="image23.png"/><wp:cNvGraphicFramePr/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="image23.png"/><pic:cNvPicPr preferRelativeResize="0"/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId9"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="4391025" cy="4446905"/></a:xfrm><a:prstGe