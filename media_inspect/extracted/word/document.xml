llRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="4124325" cy="2362200"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln/></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="359AFB2E" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="15A2EC0E" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>I am not sure why it shows “no hints” when the puzzle is no longer solvable, it may have to do with the header of the file</w:t></w:r></w:p><w:p w14:paraId="26468E7C" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="7BD4E3C4" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>If we add some more bytes as if they were extra states, they would appear to solve the puzzle more or completely. Referring to the details on how a hint is registered, we would add 10 more bytes to complete the .sol file for the above example puzzle. This is our file now with the starting point at the end of the hex values:</w:t></w:r></w:p><w:p w14:paraId="3132C34D" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="114300" distB="114300" distL="114300" distR="114300" wp14:anchorId="71167C04" wp14:editId="06A0A5BC"><wp:extent cx="5876925" cy="685800"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="5" name="image15.png"/><wp:cNvGraphicFramePr/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="image15.png"/><pic:cNvPicPr preferRelativeResize="0"/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId16"/><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5876925" cy="685800"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln/></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="037B266F" w14:textId="3DF9B7CF" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t xml:space="preserve">The starting point can be anywhere as long as it follows to a closing point that leads to state </w:t></w:r><w:r w:rsidR="00667DC1"><w:rPr><w:lang w:val="en-US"/></w:rPr><w:t>0</w:t></w:r><w:r><w:t>.</w:t></w:r></w:p><w:p w14:paraId="0C8BB491" w14:textId="77777777" w:rsidR="00667DC1" w:rsidRDefault="00667DC1"><w:r><w:br w:type="page"/></w:r></w:p><w:p w14:paraId="267E326A" w14:textId="49E21A4E" w:rsidR="004C40AA" w:rsidRDefault="00667DC1"><w:r><w:rPr><w:noProof/></w:rPr><w:lastRenderedPageBreak/><w:drawing><wp:anchor distT="0" distB="0" distL="114300" distR="114300" simplePos="0" relativeHeight="251666432" behindDoc="0" locked="0" layoutInCell="1" allowOverlap="1" wp14:anchorId="5C02CF93" wp14:editId="3B752B83"><wp:simplePos x="0" y="0"/><wp:positionH relativeFrom="margin"><wp:align>right</wp:align></wp:positionH><wp:positionV relativeFrom="margin"><wp:posOffset>266700</wp:posOffset></wp:positionV><wp:extent cx="5724525" cy="5943600"/><wp:effectExtent l="0" t="0" r="9525" b="0"/><wp:wrapTopAndBottom/><wp:docPr id="3" name="image20.gif"/><wp:cNvGraphicFramePr/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="image20.gif"/><pic:cNvPicPr preferRelativeResize="0"/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId17"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5724525" cy="5943600"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln/></pic:spPr></pic:pic></a:graphicData></a:graphic><wp14:sizeRelH relativeFrom="margin"><wp14:pctWidth>0</wp14:pctWidth></wp14:sizeRelH><wp14:sizeRelV relativeFrom="margin"><wp14:pctHeight>0</wp14:pctHeight></wp14:sizeRelV></wp:anchor></w:drawing></w:r><w:r><w:t>Let’s take a look at how it looks ingame now</w:t></w:r></w:p><w:p w14:paraId="5260C7ED" w14:textId="38F5D466" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"><w:pPr><w:jc w:val="center"/></w:pPr></w:p><w:p w14:paraId="43B42E25" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>That looks good and it shows exactly what we have to do to solve the demo puzzle!</w:t></w:r></w:p><w:p w14:paraId="725B1103" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="004C40AA"/><w:p w14:paraId="2AA89C8C" w14:textId="5963CC78" w:rsidR="00667DC1" w:rsidRDefault="00667DC1"><w:r><w:br w:type="page"/></w:r></w:p><w:p w14:paraId="218A7576" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:bookmarkStart w:id="5" w:name="_xw1hm134faxh" w:colFirst="0" w:colLast="0"/><w:bookmarkEnd w:id="5"/><w:r><w:lastRenderedPageBreak/><w:t>Two-way solutions (and everything that contains more than one solution)</w:t></w:r></w:p><w:p w14:paraId="57C8F819" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:r><w:t>Some hints are two-ways (puzzles having more than one solution) and the user could follow one or the other to solve the puzzle, or follow both on certain occasions.</w:t></w:r></w:p><w:p w14:paraId="53E2B4D1" w14:textId="77777777" w:rsidR="004C40AA" w:rsidRDefault="00000000"><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="114300" distB="114300" distL="114300" distR="114300" wp14:anchorId="65800815" wp14:edi